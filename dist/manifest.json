{
  "manifest_version": 3,
  "name": "SF Solution Crawler",
  "version": "0.3.0",
  "description": "AI-powered Salesforce opportunity crawler for generating NICE WFM Solution Design Documents",
  "permissions": ["storage", "activeTab", "sidePanel", "tabs"],
  "host_permissions": [
    "https://*.salesforce.com/*",
    "https://*.force.com/*",
    "https://*.lightning.force.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://api.groq.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.salesforce.com/*",
        "https://*.force.com/*",
        "https://*.lightning.force.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "SF Solution Crawler"
  },
  "web_accessible_resources": [
    {
      "resources": ["templates/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
